<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Vektor does not track users. No analytics SDKs, no identifiers
         sent off-device, no advertising, no cross-app correlation. -->
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- Vektor does not collect data centrally. Documents, settings,
         and API keys stay on the user's Mac (UserDefaults + the app
         sandbox container). Third-party services that Vektor
         optionally talks to (aviationweather.gov, frankfurter.dev,
         coingecko, datis.clowd.io, financialmodelingprep.com) are
         documented separately in PRIVACY.md. -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- Required-reason API declarations. UserDefaults is the only
         such API Vektor uses. -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: "Declare this reason to access user
                     defaults to read and write information that is
                     only accessible to the app itself." Vektor reads
                     and writes its own UserDefaults container only;
                     never another app's defaults via App Groups or
                     any other shared mechanism. -->
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
