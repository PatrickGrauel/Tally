{
  "name": "sumi-js",
  "version": "0.1.0",
  "description": "math.js bundler for Sumi (loaded into JSContext at runtime)",
  "private": true,
  "scripts": {
    "build": "esbuild entry.js --bundle --format=iife --global-name=SumiJS --minify --target=es2020 --outfile=../Packages/SumiEngine/Sources/SumiEngine/Resources/mathjs.bundle.js",
    "build:dev": "esbuild entry.js --bundle --format=iife --global-name=SumiJS --target=es2020 --outfile=../Packages/SumiEngine/Sources/SumiEngine/Resources/mathjs.bundle.js"
  },
  "dependencies": {
    "mathjs": "^13.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.23.0"
  }
}
